# ─── REDIS ───
# PRODUCTION (Upstash):
# REDIS_URL="rediss://default:[PASSWORD]@[host].upstash.io:6379"
#
# DEVELOPMENT (Docker):
REDIS_URL="redis://localhost:6379"
# Alternatively, use host/port:
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ─── WEBHOOK ───
WEBHOOK_SECRET="replace-with-a-long-random-string"
WEBHOOK_URL="http://localhost:3003/bankWebhook"

# ─── CORS ───
CORS_ORIGIN="http://localhost:3001"

# ─── ADMIN ───
ADMIN_API_TOKEN=""
ADMIN_IP_ALLOWLIST=""

# ─── DLQ AUTO-REDRIVE ───
DLQ_AUTO_REDRIVE_ENABLED=false
DLQ_AUTO_REDRIVE_INTERVAL_MS=60000
DLQ_AUTO_REDRIVE_LIMIT_PER_RUN=10
DLQ_AUTO_REDRIVE_MAX_REPLAYS_PER_JOB=3
