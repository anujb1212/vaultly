# ─── DATABASE ───
# PRODUCTION (Supabase Supavisor pooler):
# DATABASE_URL="postgresql://postgres.[project-id]:[PASSWORD]@aws-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=30"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[project-id].supabase.co:5432/postgres"
#
# DEVELOPMENT (Docker):
DATABASE_URL="postgresql://postgres:prisma@localhost:5432/vaultly?schema=public"
DIRECT_URL="postgresql://postgres:prisma@localhost:5432/vaultly?schema=public"

# ─── REDIS ───
# PRODUCTION (Upstash):
# REDIS_URL="rediss://default:[PASSWORD]@[host].upstash.io:6379"
#
# DEVELOPMENT (Docker):
REDIS_URL="redis://localhost:6379"

# ─── AUTH ───
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="replace-with-a-long-random-string"
JWT_SECRET="replace-with-a-long-random-string"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── WEBHOOK ───
WEBHOOK_SECRET="replace-with-a-long-random-string"

# ─── EMAIL (Resend) ───
RESEND_API_KEY=""
RESEND_FROM="Vaultly <noreply@vaultly.anujb.space>"
APP_URL="http://localhost:3001"

# ─── AI (Gemini) ───
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
AI_USER_DAILY_CAP=5
AI_GLOBAL_DAILY_CAP=200

# ─── ADMIN ───
GATEWAY_ADMIN_TOKEN="your_secret_token"
ADMIN_EMAILS="admin@example.com"

# ─── BRIDGE ───
BRIDGE_SECRET="bridge_secret"
ARBITIUM_SYSTEM_USER_ID=27
NEXT_PUBLIC_ARBITIUM_URL="http://localhost:5173"
