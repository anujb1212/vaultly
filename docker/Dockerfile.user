FROM node:20-alpine AS pruner
WORKDIR /usr/src/app
COPY . .
RUN npx turbo prune --scope=user-app --scope=@repo/db --docker

FROM node:20-alpine AS builder
WORKDIR /usr/src/app
ARG DATABASE_URL="postgresql://postgres:prisma@127.0.0.1:5432/vaultly?schema=public"
ENV DATABASE_URL=$DATABASE_URL
COPY --from=pruner /usr/src/app/out/json/ ./
COPY --from=pruner /usr/src/app/out/package-lock.json ./package-lock.json
RUN npm ci
COPY --from=pruner /usr/src/app/out/full/ ./
RUN npm run db:generate
RUN JWT_SECRET=dummy NEXTAUTH_SECRET=dummy npm run build:user-app

FROM gcr.io/distroless/nodejs20-debian12:nonroot AS runner
WORKDIR /usr/src/app
ENV NODE_ENV=production
ENV PORT=3001
COPY --from=builder /usr/src/app/apps/user-app/.next/standalone ./
COPY --from=builder /usr/src/app/apps/user-app/.next/static ./apps/user-app/.next/static
COPY --from=builder /usr/src/app/apps/user-app/public ./apps/user-app/public
USER 65532
EXPOSE 3001
CMD ["apps/user-app/server.js"]